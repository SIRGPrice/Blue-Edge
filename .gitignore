# ==============================================================================
# Build / IDE / OS local state - never push.
# ==============================================================================
*.iml
.gradle/
.kotlin/
kotlin-js-store/
local.properties
.DS_Store
Thumbs.db
# Project / module build outputs.
/build/
**/build/
/captures/
.externalNativeBuild/
.cxx/
# JetBrains / Android Studio local user state.
.idea/
# iOS / Xcode (generated locally on macOS).
iosApp/Pods/
iosApp/*.xcodeproj/
iosApp/*.xcworkspace/
iosApp/Podfile.lock
iosApp/build/
xcuserdata/
*.xcuserstate
DerivedData/
# ==============================================================================
# Logs / crash dumps (developer-local, never push).
# ==============================================================================
*.log
full.log
tombstone.txt
app_crash_filtered.txt
hs_err_pid*.log
# ==============================================================================
# Secrets - must never be committed.
# ==============================================================================
*.keystore
*.jks
*.p12
*.mobileprovision
*.p8
*.pem
*.key
ExportOptions.plist
google-services.json
GoogleService-Info.plist
.env
.env.*
